{
  "rewrites": [
    { "source": "/news/:id", "destination": "/api/news/:id" },
    {
      "source": "/backend/:path*",
      "destination": "https://camify.fun.coinsclarity.com/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
