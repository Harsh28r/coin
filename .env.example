# Copy to `.env` for local builds. AdSense: create display ad units in AdSense UI, then paste slot IDs (numeric only).

# Fallback used for every placement unless a specific slot is set below.
# REACT_APP_ADSENSE_SLOT_DISPLAY=1234567890

# Optional — per placement (better reporting in AdSense).
# REACT_APP_ADSENSE_SLOT_BLOG_ATF=
# REACT_APP_ADSENSE_SLOT_BLOG_MID=
# REACT_APP_ADSENSE_SLOT_BLOG_BTF=
# REACT_APP_ADSENSE_SLOT_COIN_MID=
# REACT_APP_ADSENSE_SLOT_COIN_BTF=
# REACT_APP_ADSENSE_SLOT_TOOLS_ATF=
# REACT_APP_ADSENSE_SLOT_TOOLS_MID=
# REACT_APP_ADSENSE_SLOT_COMPARE_MID=
# REACT_APP_ADSENSE_SLOT_COMPARE_BTF=

# Homepage (optional — each falls back to REACT_APP_ADSENSE_SLOT_LANDING then DISPLAY).
# REACT_APP_ADSENSE_SLOT_LANDING=
# REACT_APP_ADSENSE_SLOT_LANDING_A=
# REACT_APP_ADSENSE_SLOT_LANDING_B=
# REACT_APP_ADSENSE_SLOT_LANDING_C=

# Optional: override dashboard default admin secret (built-in default matches backend .env.example ADMIN_SECRET).
# REACT_APP_ADMIN_SECRET_DEFAULT=9a098c3d57c14746a1fe7ac261f5f7aa
